  "keyFeatures": [
    "S3 bucket creation with full configuration support",
    "Server-side encryption (SSE-S3, SSE-KMS)",
    "Cross-Region Replication (CRR)",
    "Object versioning and lifecycle rules",
    "Access logging for ELB, ALB/NLB, WAF, CloudTrail",
    "Intelligent-Tiering configuration",
    "Object Lock (WORM compliance)",
    "S3 Directory Bucket support",
    "S3 Table Bucket support",
    "Public Access Block configuration",
    "CORS configuration",
    "Static website hosting",
    "Bucket inventory and analytics",
    "Terragrunt compatibility"
  ],
